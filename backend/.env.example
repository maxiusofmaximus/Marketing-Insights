# Configuración local recomendada con Ollama
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Opcional: proveedores cloud
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-tu-clave-aqui

# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-tu-clave-aqui

# LLM_PROVIDER=gemini
# GEMINI_API_KEY=tu-clave-aqui

# Si no configuras ningún LLM, el sistema funciona igual
# pero las respuestas serán directas sin interpretación de negocio

# Puerto del servidor
PORT=8000
